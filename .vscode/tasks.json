{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "C/C++: g++ build active file",
			"command": "/bin/bash",
			"args": [
				"-c",
				"mkdir -p ${workspaceFolder}/bin && /usr/bin/g++ -fdiagnostics-color=always -std=c++20 -g ${fileDirname}/*.cpp -o ${workspaceFolder}/bin/${fileBasenameNoExtension}"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"detail": "compiler: /usr/bin/g++"
		}
	]
}